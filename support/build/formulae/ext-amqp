#!/usr/bin/env bash

# fail hard
set -o pipefail
# fail harder
set -eu

dep_name=$(basename "$BASH_SOURCE")

dep_package=${0#"${WORKSPACE_DIR}/"} # trim WORKSPACE_DIR prefix from $0 (the invoked package recipe)
dep_build=${dep_package#"${dep_name}-"} # strip formula name from front of full package name

if [[ $dep_build == 1.* && $STACK != "heroku-22" ]]; then
	echo "Version not supported on stack ${STACK}, skipping."
	exit 9
fi

# let's see if librabbitmq is there
needed=( librabbitmq4 )
missing=$(comm -1 -3 <(dpkg-query -W -f '${package}\n' | sort) <(IFS=$'\n'; echo "${needed[*]}" | sort))
if [[ "$missing" ]]; then
	echo "Need $missing"; exit 1;
fi

# but do we need headers?
needed=( librabbitmq-dev )
missing=$(comm -1 -3 <(dpkg-query -W -f '${package}\n' | sort) <(IFS=$'\n'; echo "${needed[*]}" | sort))
if [[ "$missing" ]]; then
	apt-get update -qq || { echo "Failed to 'apt-get update'. You must build this formula using Docker."; exit 1; }
	apt-get install -q -y $missing
fi

source "$(dirname "$BASH_SOURCE")/include/pecl-ext"
