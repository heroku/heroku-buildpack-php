#!/usr/bin/env bash

dep_name=$(basename "$BASH_SOURCE")

dep_package=${0#"${WORKSPACE_DIR}/"} # trim WORKSPACE_DIR prefix from $0 (the invoked package recipe)
dep_build=${dep_package#"${dep_name}-"} # strip formula name from front of full package name

OUT_PREFIX=$1
export PATH=${OUT_PREFIX}/bin:${PATH}

php_series=$(php-config --version | cut -d. -f1,2) # get "7.3", "7.4", "8.0" etc for the php requirement in the manifest
# we need to declare the required version of librdkafka
# for heroku-22 it's 1.x, otherwise 2.x
if [[ $STACK == "heroku-22" ]]; then
	librdkafka_version="1.*"
else
	librdkafka_version="2.*"
fi

MANIFEST_REQUIRE="${MANIFEST_REQUIRE:-"{\"heroku-sys/php\":\"${php_series}.*\",\"heroku-sys/librdkafka\":\"${librdkafka_version}\",\"heroku-sys/librdkafka-abi\":\"^1\"}"}"

CONFIGURE_EXTRA="--with-rdkafka=${OUT_PREFIX}"

from_ext_to_lib=$(realpath --relative-to="$(php-config --extension-dir)" "${OUT_PREFIX}/lib")

MAKE_EXTRA="LDFLAGS=${LDFLAGS:--Wl},-rpath='\$\$ORIGIN/${from_ext_to_lib}'"

source "$(dirname "$BASH_SOURCE")/include/pecl-ext"
